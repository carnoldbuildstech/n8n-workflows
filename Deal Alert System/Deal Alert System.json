        "jsCode": "const title = $json.title.toLowerCase();\nconst description = ($json.description || '').toLowerCase();\nconst text = title + ' ' + description;\n\nconst keywords = [\n  // Brands — tools\n  'dewalt', 'milwaukee', 'ryobi', 'makita', 'bosch', 'craftsman', 'ridgid',\n  // Generic tools\n  'drill', 'saw', 'wrench', 'plier', 'screwdriver', 'hammer', 'socket',\n  'impact', 'sander', 'grinder', 'level', 'clamp', 'staple gun',\n  'worklight', 'multimeter', 'utility knife', 'tape measure',\n  // PC parts\n  'gpu', 'cpu', 'ram', 'ssd', 'nvme', 'graphics card', 'processor',\n  'motherboard', 'pc part', 'keyboard', 'mouse', 'monitor', 'webcam',\n  // Audio\n  'headphone', 'earbuds', 'airpods', 'speaker', 'soundbar', 'bose',\n  'sony', 'jabra', 'beats', 'jbl',\n  // TV/Display\n  'tv', 'oled', 'qled', '4k', '8k', 'projector', 'television',\n  // Smart home\n  'ring', 'nest', 'echo', 'alexa', 'smart plug', 'smart bulb', 'wyze',\n  // Cameras\n  'camera', 'gopro', 'dashcam', 'security cam',\n  // Gaming\n  'nintendo', 'xbox', 'playstation', 'gaming', 'steam deck', 'controller',\n  'video game',\n  // Toys\n  'lego', 'nerf', 'toy', 'action figure',\n  // Kitchen appliances\n  'air fryer', 'instant pot', 'blender', 'coffee maker', 'keurig',\n  'pressure cooker', 'vacuum', 'dyson', 'shark',\n  // Tablets/Wearables\n  'ipad', 'tablet', 'kindle', 'smartwatch', 'apple watch', 'fitbit'\n];\n\nconst matched = keywords.some(keyword => text.includes(keyword));\n\nif (matched) {\n  return [$input.item];\n}\n\nreturn [];\n"
