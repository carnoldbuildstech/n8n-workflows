    {
      "parameters": {
        "jsCode": "const keywords = ['fire', 'gas', 'leak', 'flood', 'smoke', 'locked out', 'break-in'];\n\nconst message = $input.first().json.message?.toLowerCase() || '';\n\nconst matchedKeyword = keywords.find(kw => message.includes(kw));\n\nif (matchedKeyword) {\n  return [{\n    json: {\n      message: $input.first().json.message,\n      tenantName: $input.first().json.tenantName,\n      unit: $input.first().json.unit,\n      channel: $input.first().json.channel,\n      category: 'EMERGENCY',\n      flagReason: `Keyword match: \"${matchedKeyword}\"`,\n      skipAI: true\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    message: $input.first().json.message,\n    tenantName: $input.first().json.tenantName,\n    unit: $input.first().json.unit,\n    channel: $input.first().json.channel,\n    category: null,\n    flagReason: null,\n    skipAI: false\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-864, -384],
      "id": "be14d97c-98fd-4a17-ba98-adfffe8b458b",
      "name": "Keyword Filter"
    },
