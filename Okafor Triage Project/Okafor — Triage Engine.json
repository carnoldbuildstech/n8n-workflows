    {
      "parameters": {
        "jsCode": "const aiOutput = $input.first().json.output?.trim().toUpperCase() || 'AMBIGUOUS';\n\nconst validCategories = ['EMERGENCY', 'MAINTENANCE', 'BILLING', 'AMBIGUOUS'];\nconst category = validCategories.includes(aiOutput) ? aiOutput : 'AMBIGUOUS';\n\nconst originalData = $('Keyword Filter').first().json;\n\nreturn [{\n  json: {\n    message: originalData.message,\n    tenantName: originalData.tenantName,\n    unit: originalData.unit,\n    channel: originalData.channel,\n    category: category,\n    flagReason: originalData.skipAI ? originalData.flagReason : 'AI categorization — potential safety risk',\n    skipAI: originalData.skipAI\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
