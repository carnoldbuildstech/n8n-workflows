        "promptType": "define",
        "text": "=Draft a financial summary email for the following client:\n\nClient Name: {{ $('Webhook').item.json.body.clientName }}\nRevenue: {{ $('Webhook').item.json.body.revenue }}\nExpenses: {{ $('Webhook').item.json.body.expenses }}\nNet Profit: {{ $('Webhook').item.json.body.netProfit }}\nNotable Items: {{ $('Webhook').item.json.body.notableItems }}\n",
        "options": {
          "systemMessage": "[system prompt redacted]"
        }
      },
