      "name": "AI Agent"
    },
    {
      "parameters": {
        "jsCode": "const draft = $input.first().json.output;\nconst body = $('Webhook').first().json.body ?? $('Webhook').first().json;\n\n// Strip $, commas, and spaces for normalized comparison\nfunction normalize(val) {\n  return String(val).replace(/[$,\\s]/g, '');\n}\n\nconst figures = {\n  revenue: body.revenue,\n  expenses: body.expenses,\n  netProfit: body.netProfit\n};\n\nconst errors = [];\nconst normalizedDraft = normalize(draft);\n\n// Check all three dollar figures appear (normalized)\nfor (const [key, val] of Object.entries(figures)) {\n  if (!normalizedDraft.includes(normalize(val))) {\n    errors.push(`missing figure: ${key} (${val})`);\n  }\n}\n\n// Word count\nconst wordCount = draft.trim().split(/\\s+/).length;\nif (wordCount < 100) errors.push(`too short (${wordCount} words — minimum 100)`);\nif (wordCount > 400) errors.push(`too long (${wordCount} words — maximum 400)`);\n\n// Hedging language\nconst draftLower = draft.toLowerCase();\nconst hedging = ['approximately', 'around', 'i think', 'roughly'];\nfor (const phrase of hedging) {\n  if (draftLower.includes(phrase)) {\n    errors.push(`hedging language: \"${phrase}\"`);\n  }\n}\n\nreturn [{\n  json: {\n    valid: errors.length === 0,\n    errors,\n    errorSummary: errors.join('; '),\n    draft,\n    wordCount,\n    clientName: body.clientName\n  }\n}];\n"
      },
